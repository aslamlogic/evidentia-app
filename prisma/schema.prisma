generator client {
    provider = "prisma-client-js"
    binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

// =============================================================================
// EVIDENTIA LEGAL INTELLIGENCE — FORMAL TECHNICAL SPEC v1.3 SCHEMA
// =============================================================================
// v1.3 Changes (22 March 2026):
//   - Removed: reviewer role (redundant)
//   - Added:   user_admin role (firm-level admin, capped at 1 per org)
//   - Added:   Organisation model (tier belongs to firm, not individual)
//   - Added:   organisationId FK on User
//   - subscriptionTier retained on User for JWT compatibility (derived from Org)
// =============================================================================

// ---------------------------------------------------------------------------
// ENUMS
// ---------------------------------------------------------------------------

enum UserRole {
  user
  user_admin
  admin
  superuser
}

enum MatterStatus {
  open
  in_progress
  closed
  archived
}

enum TierLevel {
  Basic
  Silver
  Gold
  Platinum
}

enum SubscriptionTier {
  Basic
  Silver
  Gold
  Platinum
}

enum TaskType {
  chronology
  case_summary
  laws_affected
  breaches_map
  issues_list
  defenses_prosecution
  lawyer_case_pack
  scoping_analysis
  evidence_schedule
  cause_of_action_matrix
  adversarial_analysis
}

enum TaskStatus {
  pending
  queued
  processing
  succeeded
  failed
  canceled
}

enum DocumentStatus {
  pending
  processing
  processed
  failed
}

enum SourceType {
  Statute
  Case
  Regulation
  Secondary
  Other
}

enum KnowledgeUnitModality {
  Empirical
  Normative
}

enum AdversarialFunctionType {
  rebut
  distinguish
  narrow
  reinterpret
  alternative_authority
  factual_counter
}

enum FragmentType {
  Section
  Subsection
  Paragraph
  Sentence
}

enum InvocationType {
  generation
  regeneration
  edit
  review_approve
  review_reject
  export
}

// ---------------------------------------------------------------------------
// ORGANISATION MODEL
// Tier belongs to the firm. All users within a firm share the firm's tier.
// Exactly one user_admin per organisation (enforced at API level).
// ---------------------------------------------------------------------------

model Organisation {
  id               String           @id @default(uuid())
  name             String
  slug             String           @unique
  subscriptionTier SubscriptionTier @default(Basic)
  isActive         Boolean          @default(true)
  billingEmail     String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  users            User[]

  @@map("organisations")
}

// ---------------------------------------------------------------------------
// CORE USER ENTITY
// ---------------------------------------------------------------------------

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  password         String
  firstName        String?
  lastName         String?
  role             UserRole         @default(user)
  subscriptionTier SubscriptionTier @default(Basic)  // Derived from Organisation on login. Retained for JWT compat.
  isActive         Boolean          @default(true)
  lastLoginAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Organisation FK (nullable for Evidentia admin/superuser who have no org)
  organisationId   String?
  organisation     Organisation?    @relation(fields: [organisationId], references: [id], onDelete: SetNull)

  // Relations
  matters          Matter[]
  documents        Document[]
  tasks            AITask[]
  outputs          AIOutput[]
  invocations      Invocation[]
  intakeForms      IntakeForm[]
  auditLogs        AuditLog[]

  @@map("users")
}

// ---------------------------------------------------------------------------
// ENTITY: Matter (Spec 4.1)
// ---------------------------------------------------------------------------

model Matter {
  id                      String       @id @default(uuid())
  title                   String
  description             String?
  practiceArea            String       @default("general")
  jurisdiction            String       @default("England and Wales")
  matterType              String       @default("civil")
  status                  MatterStatus @default(open)
  structuredInputPayload  Json?
  clientName              String?
  clientEmail             String?
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  userId                  String
  user                    User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  documents               Document[]
  tasks                   AITask[]
  intakeForms             IntakeForm[]
  invocations             Invocation[]
  legalArtefacts          LegalArtefact[]
  knowledgeUnits          KnowledgeUnit[]

  @@map("matters")
}

// ---------------------------------------------------------------------------
// ENTITY: Invocation (Spec 4.2)
// ---------------------------------------------------------------------------

model Invocation {
  id                    String         @id @default(uuid())
  matterId              String
  matter                Matter         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  llmProviderName       String
  modelIdentifier       String
  modelRequested        String?
  temperatureValue      Float          @default(0.1)
  protocolVersion       String         @default("SMR v5.6 + KUP v1.5")
  requestPayloadHash    String?
  responseHash          String?
  invocationType        InvocationType @default(generation)
  inputTokens           Int            @default(0)
  outputTokens          Int            @default(0)
  generationTimeMs      Int            @default(0)
  tier                  String?
  complexityScore       Float?
  routingDecision       String?
  invocationTimestamp   DateTime       @default(now())
  userId                String?
  user                  User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  taskId                String?
  task                  AITask?        @relation(fields: [taskId], references: [id], onDelete: SetNull)
  sources               Source[]
  legalArtefacts        LegalArtefact[]

  @@map("invocations")
}

// ---------------------------------------------------------------------------
// ENTITY: LegalArtefact (Spec 4.3)
// ---------------------------------------------------------------------------

model LegalArtefact {
  id                    String          @id @default(uuid())
  matterId              String
  matter                Matter          @relation(fields: [matterId], references: [id], onDelete: Cascade)
  tierLevel             TierLevel       @default(Basic)
  generatedText         String          @db.Text
  contentMarkdown       String?         @db.Text
  sectionsJson          Json?
  artefactType          String?
  version               Int             @default(1)
  confidence            Float?
  generatedTimestamp    DateTime        @default(now())
  invocationId          String?
  invocation            Invocation?     @relation(fields: [invocationId], references: [id], onDelete: SetNull)
  evidenceLinks         EvidenceLink[]
  fragments             ArtefactFragment[]

  @@map("legal_artefacts")
}

// ---------------------------------------------------------------------------
// ENTITY: Source (Spec 4.4)
// ---------------------------------------------------------------------------

model Source {
  id                    String       @id @default(uuid())
  invocationId          String
  invocation            Invocation   @relation(fields: [invocationId], references: [id], onDelete: Cascade)
  citationText          String       @db.Text
  sourceType            SourceType   @default(Other)
  referencedSection     String?
  jurisdiction          String?
  yearPublished         Int?
  verified              Boolean      @default(false)
  verificationNotes     String?
  extractedTimestamp    DateTime     @default(now())
  evidenceLinks         EvidenceLink[]

  @@map("sources")
}

// ---------------------------------------------------------------------------
// ENTITY: EvidenceLink (Spec 4.5)
// ---------------------------------------------------------------------------

model EvidenceLink {
  id                        String         @id @default(uuid())
  artefactId                String
  artefact                  LegalArtefact  @relation(fields: [artefactId], references: [id], onDelete: Cascade)
  sourceId                  String
  source                    Source         @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fragmentIdentifier        String?
  fragmentTextHash          String?
  relevanceScore            Float?
  linkageType               String?
  linkageCreatedTimestamp   DateTime       @default(now())

  @@unique([artefactId, sourceId, fragmentIdentifier])
  @@map("evidence_links")
}

// ---------------------------------------------------------------------------
// ENTITY: ArtefactFragment (Spec 4.6)
// ---------------------------------------------------------------------------

model ArtefactFragment {
  id                    String          @id @default(uuid())
  artefactId            String
  artefact              LegalArtefact   @relation(fields: [artefactId], references: [id], onDelete: Cascade)
  fragmentType          FragmentType    @default(Paragraph)
  fragmentOrderIndex    Int
  fragmentText          String          @db.Text
  fragmentTextHash      String?
  sectionName           String?
  headingLevel          Int?
  createdAt             DateTime        @default(now())

  @@map("artefact_fragments")
}

// ---------------------------------------------------------------------------
// ENTITY: KnowledgeUnit (Spec 4.7)
// ---------------------------------------------------------------------------

model KnowledgeUnit {
  id                        String                 @id @default(uuid())
  matterId                  String
  matter                    Matter                 @relation(fields: [matterId], references: [id], onDelete: Cascade)
  modality                  KnowledgeUnitModality
  quotationText             String                 @db.Text
  analyticalParaphrase      String                 @db.Text
  interpretiveCommentary    String                 @db.Text
  sourceReference           String?
  confidence                Float?
  tierExtracted             TierLevel?
  orderIndex                Int                    @default(0)
  createdAt                 DateTime               @default(now())
  adversarialKUsTargeting   AdversarialKnowledgeUnit[] @relation("TargetKU")
  adversarialKUsBase        AdversarialKnowledgeUnit[] @relation("BaseKU")

  @@map("knowledge_units")
}

// ---------------------------------------------------------------------------
// ENTITY: AdversarialKnowledgeUnit (Spec 4.8)
// ---------------------------------------------------------------------------

model AdversarialKnowledgeUnit {
  id                    String                   @id @default(uuid())
  kuId                  String
  baseKU                KnowledgeUnit            @relation("BaseKU", fields: [kuId], references: [id], onDelete: Cascade)
  targetKuId            String
  targetKU              KnowledgeUnit            @relation("TargetKU", fields: [targetKuId], references: [id], onDelete: Cascade)
  functionType          AdversarialFunctionType
  strengthRating        Int                      @default(2)
  adversarialArgument   String                   @db.Text
  additionalSources     Json?
  reinterpretation      String?                  @db.Text
  createdAt             DateTime                 @default(now())

  @@map("adversarial_knowledge_units")
}

// ---------------------------------------------------------------------------
// EXISTING ENTITIES (ENHANCED)
// ---------------------------------------------------------------------------

model Document {
  id                    String         @id @default(uuid())
  filename              String
  originalName          String
  mimeType              String
  fileSize              Int
  storagePath           String
  status                DocumentStatus @default(pending)
  contentHash           String?
  extractedText         String?        @db.Text
  extractedFacts        Json?
  charCount             Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  matterId              String
  matter                Matter         @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  taskDocuments         TaskDocument[]

  @@map("documents")
}

model AITask {
  id                    String       @id @default(uuid())
  taskType              TaskType
  status                TaskStatus   @default(pending)
  tierSnapshotJson      Json?
  templateSnapshotJson  Json?
  instructions          String?
  errorMessage          String?
  processingTimeMs      Int?
  smrVersion            String       @default("v5.6")
  kupVersion            String       @default("v1.5")
  protocolCompliant     Boolean      @default(false)
  createdAt             DateTime     @default(now())
  startedAt             DateTime?
  completedAt           DateTime?
  matterId              String
  matter                Matter       @relation(fields: [matterId], references: [id], onDelete: Cascade)
  userId                String
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  outputs               AIOutput[]
  taskDocuments         TaskDocument[]
  invocations           Invocation[]

  @@map("ai_tasks")
}

model AIOutput {
  id                    String     @id @default(uuid())
  version               Int        @default(1)
  contentMarkdown       String     @db.Text
  sectionsJson          Json?
  citationsJson         Json?
  confidence            Float?
  smrCompliant          Boolean    @default(false)
  lwpCompliant          Boolean    @default(false)
  complianceDetails     Json?
  aiProvider            String?
  aiModel               String?
  tokensUsed            Int?
  generationTimeMs      Int?
  exportPdfUrl          String?
  exportDocxUrl         String?
  createdAt             DateTime   @default(now())
  taskId                String
  task                  AITask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  userId                String?
  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("ai_outputs")
}

model TaskDocument {
  id                    String     @id @default(uuid())
  taskId                String
  task                  AITask     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  documentId            String
  document              Document   @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([taskId, documentId])
  @@map("task_documents")
}

model IntakeForm {
  id                    String       @id @default(uuid())
  title                 String
  answersJson           Json?
  completenessScore     Float        @default(0)
  locked                Boolean      @default(false)
  lockedAt              DateTime?
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  matterId              String?
  matter                Matter?      @relation(fields: [matterId], references: [id], onDelete: SetNull)
  userId                String
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fields                IntakeField[]

  @@map("intake_forms")
}

model IntakeField {
  id                    String     @id @default(uuid())
  fieldName             String
  fieldType             String
  fieldValue            String?    @db.Text
  required              Boolean    @default(false)
  orderIndex            Int        @default(0)
  createdAt             DateTime   @default(now())
  intakeFormId          String
  intakeForm            IntakeForm @relation(fields: [intakeFormId], references: [id], onDelete: Cascade)

  @@map("intake_fields")
}

model AuditLog {
  id                    String     @id @default(uuid())
  action                String
  objectType            String
  objectId              String?
  metadataJson          Json?
  ipAddress             String?
  userAgent             String?
  timestamp             DateTime   @default(now())
  userId                String?
  user                  User?      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model ComplexityScore {
  id                        String     @id @default(uuid())
  matterId                  String     @unique
  documentCount             Int        @default(0)
  partyCount                Int        @default(0)
  statuteCount              Int        @default(0)
  jurisdictionalLayers      Int        @default(1)
  temporalSpanMonths        Int        @default(0)
  empiricalKuCount          Int        @default(0)
  normativeKuCount          Int        @default(0)
  interactionDensity        Float      @default(0)
  frictionCoefficient       Float      @default(1.0)
  tier1Score                Float?
  tier2Score                Float?
  tier3Score                Float?
  tier4Score                Float?
  finalComplexityScore      Float?
  recommendedTier           TierLevel  @default(Basic)
  routingReason             String?
  calculatedAt              DateTime   @default(now())
  updatedAt                 DateTime   @updatedAt

  @@map("complexity_scores")
}
